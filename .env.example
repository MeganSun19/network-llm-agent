# LLM backend (OpenAI-compatible)
# Required:
OPENAI_API_KEY=sk-replace-me

# Optional — defaults shown:
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_TIMEOUT=60

# Device inventory password decryption (Fernet)
# Provide either FERNET_KEY directly:
# FERNET_KEY=replace-with-base64-fernet-key
# ...or point at a file containing it:
# FERNET_KEY_FILE=/run/secrets/fernet.key

# Agent runtime tuning
# AGENT_DEBUG=1
# MAX_TOOL_ROUNDS=3
